# Environment Variables Configuration
# Copy this file to .env.local and fill in your values

# ============================================================================
# ANALYTICS & TRACKING
# ============================================================================

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================================
# SOCIAL MEDIA INTEGRATION
# ============================================================================

# GitHub Personal Access Token (for GitHub stats)
# Create at: https://github.com/settings/tokens
# Required scopes: public_repo, read:user
NEXT_PUBLIC_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ============================================================================
# EMAIL FUNCTIONALITY (EmailJS)
# ============================================================================

# EmailJS Service ID
# Get from: https://www.emailjs.com/
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxxx

# EmailJS Template ID for Newsletter
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_newsletter

# EmailJS Template ID for Contact Form
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=template_contact

# EmailJS Public Key
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# OPTIONAL: DEVELOPMENT
# ============================================================================

# Enable debug mode (development only)
NEXT_PUBLIC_DEBUG=false

# ============================================================================
# OPTIONAL: EXTERNAL APIs
# ============================================================================

# Picsum API (for placeholder images)
# Default: https://picsum.photos
NEXT_PUBLIC_PICSUM_BASE_URL=https://picsum.photos

# ============================================================================
# KEYSTATIC CMS
# ============================================================================

# GitHub Personal Access Token (read-only, for content fetching in production)
# Create at: https://github.com/settings/tokens
# Required scopes: contents:read (for public repos, this can be omitted to avoid rate limits)
KEYSTATIC_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx