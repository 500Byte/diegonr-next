# Environment Variables Configuration
# Copy this file to .env.local and fill in your values

# ============================================================================
# ANALYTICS & TRACKING
# ============================================================================

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================================
# I18N TRANSLATION (DeepL API)
# ============================================================================

# DeepL API Key for automatic translations
# Get from: https://www.deepl.com/pro-api
# Use api-free.deepl.com for free plan, api.deepl.com for Pro
DEEPL_API_KEY=your-deepl-api-key-here

# ============================================================================
# OPTIONAL: DEVELOPMENT
# ============================================================================

# Enable debug mode (development only)
NEXT_PUBLIC_DEBUG=false


# ============================================================================
# EMAILJS (deprecated — replaced by Resend)
# ============================================================================

# EmailJS Service ID
# Get from: https://www.emailjs.com/
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your-service-id

# EmailJS Template ID (Contact Form)
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=your-contact-template-id

# EmailJS Template ID (Newsletter)
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your-newsletter-template-id

# EmailJS Public Key
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your-public-key

# ============================================================================
# RESEND (Email API)
# ============================================================================

# Resend API Key
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Destination email for contact form submissions
CONTACT_FORM_TO_EMAIL=diegolnr3@gmail.com

# Sender email (must be from your verified domain on Resend, or use onboarding@resend.dev for testing)
CONTACT_FORM_FROM_EMAIL=onboarding@resend.dev

# ============================================================================
# CLOUDFLARE TURNSTILE (Captcha)
# ============================================================================

# Turnstile Site Key (public — used in client)
# Get from: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-sitekey

# Turnstile Secret Key (private — used in API route for verification)
TURNSTILE_SECRET_KEY=your-secret-key

# ============================================================================
# CONTACT FORM
# ============================================================================

# ============================================================================
# SANITY CMS
# ============================================================================

# Sanity Project ID
# Get from: https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id

# Sanity Dataset Name
# Default: production
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API Token (Optional, for draft previews)
# Create at: Sanity Manage -> Settings -> API -> Tokens
SANITY_API_TOKEN=

