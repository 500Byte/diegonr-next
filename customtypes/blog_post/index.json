{
  "id": "blog_post",
  "label": "Blog Post",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": "Unique identifier (slug)"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Post Title"
        }
      },
      "date": {
        "type": "Date",
        "config": {
          "label": "Publication Date"
        }
      },
      "category": {
        "type": "Text",
        "config": {
          "label": "Category Name",
          "placeholder": "e.g. Technology"
        }
      },
      "read_time": {
        "type": "Text",
        "config": {
          "label": "Read Time",
          "placeholder": "e.g. 5 min"
        }
      },
      "excerpt": {
        "type": "StructuredText",
        "config": {
          "label": "Excerpt",
          "placeholder": "Brief summary...",
          "multi": "paragraph"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Cover Image",
          "constraint": {
            "width": 1200,
            "height": 630
          },
          "thumbnails": []
        }
      },
      "author": {
        "type": "Text",
        "config": {
          "label": "Author Name",
          "placeholder": "e.g. Diego NR"
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
          "fields": {
            "tag": {
              "type": "Text",
              "config": {
                "label": "Tag Name"
              }
            }
          }
        }
      },
      "content": {
        "type": "StructuredText",
        "config": {
          "label": "Post Content",
          "placeholder": "Main content body...",
          "multi": "paragraph,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,list-item,o-list-item,preformatted"
        }
      }
    }
  }
}
