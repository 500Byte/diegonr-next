{
  "id": "project",
  "label": "Project",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": "Unique identifier (slug)"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Project Title"
        }
      },
      "category": {
        "type": "Group",
        "config": {
          "label": "Category",
          "fields": {
            "item": {
              "type": "Text",
              "config": {
                "label": "Category Name"
              }
            }
          }
        }
      },
      "year": {
        "type": "Text",
        "config": {
          "label": "Year",
          "placeholder": "e.g. 2024"
        }
      },
      "description_es": {
        "type": "StructuredText",
        "config": {
          "label": "Short Description (ES)",
          "placeholder": "Resumen corto en español",
          "multi": "paragraph"
        }
      },
      "description_en": {
        "type": "StructuredText",
        "config": {
          "label": "Short Description (EN)",
          "placeholder": "Short summary in English",
          "multi": "paragraph"
        }
      },
      "tech": {
        "type": "Group",
        "config": {
          "label": "Technologies",
          "fields": {
            "item": {
              "type": "Text",
              "config": {
                "label": "Technology Name"
              }
            }
          }
        }
      },
      "url": {
        "type": "Link",
        "config": {
          "label": "Project URL",
          "placeholder": "External link to project",
          "select": "web"
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured Project",
          "placeholder_false": "Regular",
          "placeholder_true": "Featured",
          "default_value": false
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Cover Image",
          "constraint": {
            "width": 1920,
            "height": 1080
          },
          "thumbnails": []
        }
      },
      "content": {
        "type": "StructuredText",
        "config": {
          "label": "Case Study Content",
          "placeholder": "Detailed case study content...",
          "multi": "paragraph,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,list-item,o-list-item,preformatted"
        }
      }
    }
  }
}
