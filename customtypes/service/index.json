{
  "id": "service",
  "label": "Service",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": "Unique identifier (slug)"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Admin Title (Admin use only)",
          "placeholder": "Unique title for internal use"
        }
      },
      "title_es": {
        "type": "Text",
        "config": {
          "label": "Title (ES)",
          "placeholder": "Título en español"
        }
      },
      "title_en": {
        "type": "Text",
        "config": {
          "label": "Title (EN)",
          "placeholder": "Title in English"
        }
      },
      "description_es": {
        "type": "StructuredText",
        "config": {
          "label": "Short Description (ES)",
          "placeholder": "Resumen corto en español",
          "multi": "paragraph"
        }
      },
      "description_en": {
        "type": "StructuredText",
        "config": {
          "label": "Short Description (EN)",
          "placeholder": "Short summary in English",
          "multi": "paragraph"
        }
      },
      "items": {
        "type": "Group",
        "config": {
          "label": "Service Items",
          "fields": {
            "es": {
              "type": "Text",
              "config": {
                "label": "Item Name (ES)"
              }
            },
            "en": {
              "type": "Text",
              "config": {
                "label": "Item Name (EN)"
              }
            }
          }
        }
      },
      "order": {
        "type": "Number",
        "config": {
          "label": "Display Order",
          "placeholder": "e.g. 1"
        }
      },
      "content": {
        "type": "StructuredText",
        "config": {
          "label": "Service Detail Content",
          "multi": "paragraph,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,list-item,o-list-item"
        }
      }
    }
  }
}
