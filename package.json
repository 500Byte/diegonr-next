{
  "name": "diegonr-portfolio",
  "version": "2.0.0",
  "description": "Modern portfolio website for Diego NR - Solutions Architect & Full-Stack Developer",
  "author": "Diego NR <hola@diegonr.com>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "keywords": [
    "portfolio",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "gsap",
    "pwa",
    "seo",
    "cms"
  ],
  "homepage": "https://diegonr.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/diegonr/diegonr-next.git"
  },
  "bugs": {
    "url": "https://github.com/diegonr/diegonr-next/issues"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "slicemachine": "start-slicemachine",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --no-warn-ignored",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --no-warn-ignored",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out",
    "analyze": "ANALYZE=true npm run build",
    "test": "echo \"No tests specified yet\"",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@prismicio/client": "^7.21.8",
    "@prismicio/next": "^2.2.4",
    "@prismicio/react": "^3.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "^0.546.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "nextjs-google-analytics": "^2.3.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.19.0",
    "@slicemachine/adapter-next": "^0.3.95",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.14.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.9",
    "slice-machine-ui": "^2.21.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wrangler": "^4.81.1"
  },
  "browserslist": [
    ">0.3%",
    "not ie 11",
    "not dead"
  ]
}
