{
  "name": "diegonr-portfolio",
  "version": "2.0.0",
  "description": "Modern portfolio website for Diego NR - Solutions Architect & Full-Stack Developer",
  "author": "Diego NR <hola@diegonr.com>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "keywords": [
    "portfolio",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "gsap",
    "pwa",
    "seo",
    "cms"
  ],
  "homepage": "https://diegonr.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/500byte/diegonr-next.git"
  },
  "bugs": {
    "url": "https://github.com/500byte/diegonr-next/issues"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "next build",
    "dev": "npm run clean:dev && next dev",
    "dev:clean": "npm run clean:all && next dev",
    "start": "next start",
    "clean": "rm -rf .next out",
    "clean:dev": "rm -rf .next .open-next .wrangler",
    "clean:all": "rm -rf .next out .open-next .wrangler node_modules/.cache",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --no-warn-ignored",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --no-warn-ignored",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true npm run build",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@portabletext/react": "^6.0.3",
    "@portabletext/types": "^4.0.2",
    "@sanity/image-url": "^2.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "^0.546.0",
    "next": "^16.2.3",
    "next-intl": "^4.9.1",
    "next-sanity": "^12.2.2",
    "next-themes": "^0.4.6",
    "nextjs-google-analytics": "^2.3.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.19.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.14.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wrangler": "^4.81.1"
  },
  "browserslist": [
    ">0.3%",
    "not ie 11",
    "not dead"
  ]
}
